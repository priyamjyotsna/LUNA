# Neon PostgreSQL — pooled connection string (host usually contains "-pooler")
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
# Local dev. On Vercel set NEXTAUTH_URL to your live origin, e.g. https://luna-lake-seven.vercel.app
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_EMAIL="mailto:you@example.com"

# Optional — public site URL (metadata, Open Graph). Production:
# NEXT_PUBLIC_APP_URL="https://luna-lake-seven.vercel.app"

# Optional — Capacitor shell (no trailing slash). Overrides default in capacitor.config.ts when you
# run `npm run cap:sync:ios`. Not read from Vercel: sync runs locally / in CI, not on the Next server.
# CAPACITOR_SERVER_URL="https://luna-lake-seven.vercel.app"
