# Neon PostgreSQL — pooled connection string (host usually contains "-pooler")
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_EMAIL="mailto:you@example.com"

# Optional — public site URL (metadata, Open Graph)
# NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# Optional — Capacitor iOS shell loads this origin (same as production, no trailing slash)
# CAPACITOR_SERVER_URL="https://your-app.vercel.app"
