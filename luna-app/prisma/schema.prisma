generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  /// Vercel / team convention: prefixed var. For Prisma this exact name must be set (value = Neon pooled URL).
  url      = env("LUNA_DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id               String       @id @default(cuid())
  name             String?
  email            String?      @unique
  emailVerified    DateTime?
  image            String?
  password         String?
  dateOfBirth      DateTime?
  averageCycleLen  Int          @default(28)
  lutealPhaseLen   Int          @default(14)
  periodDuration   Int          @default(5)
  mode             String       @default("avoid")
  notificationsOn  Boolean      @default(true)
  pushSubscription String?
  theme            String       @default("light")
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  accounts         Account[]
  sessions         Session[]
  periodLogs       PeriodLog[]
  symptomLogs      SymptomLog[]
}

model PeriodLog {
  id             String    @id @default(cuid())
  userId         String
  periodStart    DateTime
  periodEnd      DateTime?
  cycleLength    Int?
  flowIntensity  String?
  /** True only when the user explicitly chose flow in the app (POST/PATCH). Import/raw DB noise stays hidden. */
  flowUserEntered Boolean   @default(false)
  isAnomaly      Boolean   @default(false)
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, periodStart])
}

model SymptomLog {
  id               String    @id @default(cuid())
  userId           String
  logDate          DateTime
  cycleDay         Int?
  phase            String?
  cramps           Int?
  headache         Boolean   @default(false)
  bloating         Boolean   @default(false)
  nausea           Boolean   @default(false)
  backPain         Boolean   @default(false)
  breastTenderness Boolean   @default(false)
  fatigue          Boolean   @default(false)
  acne             Boolean   @default(false)
  mood             String?
  energyLevel      Int?
  anxietyLevel     Int?
  libido           Int?
  sleepHours       Float?
  exercised        Boolean   @default(false)
  stressLevel      Int?
  waterIntake      Float?
  cervicalMucus    String?
  spotting         Boolean   @default(false)
  bbt              Float?
  ovulationPain    Boolean   @default(false)
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, logDate])
  @@index([userId, logDate])
}
